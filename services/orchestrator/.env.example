HOST=0.0.0.0
PORT=7081

EXECUTION_MODE=bridge
DEFAULT_CWD=C:/project/WhiteOps
GRAPH_STORE_PATH=C:/project/WhiteOps/.run-logs/graph-store.json
GRAPH_MAX_PARALLEL_NODES=5
GRAPH_STORE_PG_URL=postgresql://whiteops:whiteops@127.0.0.1:5432/whiteops
GRAPH_STORE_PG_TABLE=orchestrator_graph_store_snapshot

MANAGER_TIMEOUT_MS=60000
WORKER_TIMEOUT_MS=120000
MAX_TIMEOUT_MS=300000

BRIDGE_URL=http://127.0.0.1:7071
BRIDGE_AUTOSTART=true
BRIDGE_START_CMD=node
BRIDGE_START_ARGS=node_modules/tsx/dist/cli.mjs watch src/index.ts
BRIDGE_START_CWD=C:/project/WhiteOps/services/cli-bridge
BRIDGE_STARTUP_TIMEOUT_MS=45000
BRIDGE_HEALTHCHECK_INTERVAL_MS=1000
BRIDGE_REQUEST_TIMEOUT_MS=180000

API_RUN_URL=
API_REQUEST_TIMEOUT_MS=180000
API_AUTH_HEADER=Authorization
API_AUTH_TOKEN=

AUTH_ENABLED=false
AUTH_HEADER=Authorization
AUTH_TOKENS=dev-token:local-dev:admin
AUTH_DEFAULT_USER_ID=local-dev
